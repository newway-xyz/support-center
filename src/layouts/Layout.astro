---
import '../styles/global.css';
import { LANG_META, type Lang } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
  lang: Lang;
}

const { title, description, lang } = Astro.props;
const meta = LANG_META[lang];
const favicon = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.svg`;
---

<!doctype html>
<html lang={meta.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <link rel="icon" type="image/svg+xml" href={favicon} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&family=Noto+Sans+SC:wght@400;500;600;700;800&display=swap" />
    <title>{title}</title>
  </head>
  <body>
    <div class="ambient" aria-hidden="true">
      <div class="blob b1"></div>
      <div class="blob b2"></div>
      <div class="blob b3"></div>
    </div>
    <slot />
  </body>
</html>
