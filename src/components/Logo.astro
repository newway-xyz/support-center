---
import { useTranslations, localizedPath, type Lang } from '../i18n/utils';

interface Props {
  size?: number;
  showWordmark?: boolean;
  lang: Lang;
}
const { size = 36, showWordmark = true, lang } = Astro.props;
const t = useTranslations(lang);
const home = localizedPath(lang, import.meta.env.BASE_URL);
const logoSrc = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/newwaylogo.webp`;
---

<a href={home} class="logo" aria-label={`NewWay — ${t.meta.title}`}>
  <span class="mark" style={`width:${size}px;height:${size}px`}>
    <img src={logoSrc} alt="NewWay" width={size} height={size} loading="eager" decoding="async" />
  </span>
  {showWordmark && (
    <span class="wordmark">
      <span class="brand">NewWay</span>
      <span class="sub">{t.hero.title2}</span>
    </span>
  )}
</a>

<style>
  .logo { display: inline-flex; align-items: center; gap: 12px; text-decoration: none; color: inherit; }
  .mark {
    display: inline-flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .mark img {
    width: 100%; height: 100%;
    object-fit: contain;
    display: block;
  }
  .wordmark { display: flex; flex-direction: column; line-height: 1; }
  .brand { font-weight: 800; font-size: 16px; letter-spacing: -0.01em; }
  .sub { font-size: 11px; color: var(--text-quiet); font-weight: 500; margin-top: 4px; letter-spacing: 0.04em; }
</style>
