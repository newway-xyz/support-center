---
interface Props {
  size?: number;
  showWordmark?: boolean;
}
const { size = 36, showWordmark = true } = Astro.props;
---

<a href="/" class="logo" aria-label="NewWay home">
  <span class="mark" style={`width:${size}px;height:${size}px`}>
    <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="logoGrad" x1="0" x2="1" y1="0" y2="1">
          <stop offset="0" stop-color="#1E9CFF"/>
          <stop offset="1" stop-color="#0072D4"/>
        </linearGradient>
      </defs>
      <rect x="2" y="2" width="60" height="60" rx="14" fill="url(#logoGrad)"/>
      <rect x="2" y="2" width="60" height="60" rx="14" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="1"/>
      <path d="M14 48V16h7l13 20V16h7v32h-7L21 28v20z" fill="#fff"/>
      <path d="M40 16h6l3 18 5-18h4l-6 32h-6z" fill="rgba(255,255,255,0.45)"/>
    </svg>
  </span>
  {showWordmark && (
    <span class="wordmark">
      <span class="brand">NewWay</span>
      <span class="sub">Support Center</span>
    </span>
  )}
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: inherit;
  }
  .mark {
    display: inline-flex;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 6px 16px rgba(14, 136, 230, 0.28), 0 1px 0 rgba(255,255,255,0.6) inset;
  }
  .wordmark {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }
  .brand {
    font-weight: 800;
    font-size: 16px;
    letter-spacing: -0.01em;
  }
  .sub {
    font-size: 11px;
    color: var(--text-quiet);
    font-weight: 500;
    margin-top: 4px;
    letter-spacing: 0.04em;
  }
</style>
