---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="account" class="section-account">
  <div class="container">
    <header class="section-head">
      <span class="eyebrow">{t.account.eyebrow}</span>
      <h2>{t.account.heading}</h2>
    </header>

    <div class="faq glass">
      {t.account.faqs.map((f, i) => (
        <details data-search={`${f.q} ${f.a}`} open={i === 0}>
          <summary>
            <span class="q">{f.q}</span>
            <span class="plus" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
            </span>
          </summary>
          <div class="a"><p>{f.a}</p></div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq { padding: 8px 22px; }
  details { border-bottom: 1px solid var(--hairline); padding: 4px 0; }
  details:last-child { border-bottom: none; }

  summary {
    list-style: none; cursor: pointer;
    padding: 18px 4px;
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
    user-select: none;
  }
  summary::-webkit-details-marker { display: none; }
  .q { font-size: 16px; font-weight: 600; color: var(--text); }

  .plus {
    width: 32px; height: 32px; display: inline-flex; align-items: center; justify-content: center;
    border-radius: 10px;
    background: var(--surface-strong); border: 1px solid var(--border-strong); color: var(--text-muted);
    transition: transform 220ms ease, background 220ms ease, color 220ms ease;
  }
  details[open] .plus { transform: rotate(45deg); background: var(--accent); color: #fff; border-color: var(--accent); }

  .a { padding: 0 4px 22px; max-width: 70ch; }
  .a p { font-size: 15px; line-height: 1.6; }
</style>
