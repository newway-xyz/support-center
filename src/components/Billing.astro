---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="billing" class="section-billing">
  <div class="container">
    <header class="section-head">
      <span class="eyebrow">{t.billing.eyebrow}</span>
      <h2>{t.billing.heading}</h2>
    </header>

    <div class="billing glass" data-search={`${t.billing.refundQ} ${t.billing.refundA1} ${t.billing.refundA2}`}>
      <div class="b-main">
        <h3>{t.billing.refundQ}</h3>
        <p>
          <strong>{t.billing.refundA1}</strong>
          {' '}{t.billing.refundA2}
        </p>

        <div class="callout">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="9"/><path d="M12 8v4"/><path d="M12 16h.01"/>
          </svg>
          <span>{t.billing.callout}</span>
        </div>
      </div>

      <aside class="b-side">
        <span class="b-tag mono">{t.billing.directSales}</span>
        <span class="b-status">{t.billing.notAvailable}</span>
        <p>{t.billing.sideHelp}</p>
      </aside>
    </div>
  </div>
</section>

<style>
  .billing { display: grid; grid-template-columns: 1fr 280px; gap: 28px; padding: 28px 32px; align-items: stretch; }
  .b-main h3 { font-size: 22px; margin-bottom: 12px; }
  .b-main p { font-size: 15px; max-width: 60ch; }
  .b-main strong { color: var(--text); font-weight: 700; }

  .callout {
    display: inline-flex; align-items: center; gap: 10px;
    margin-top: 18px; padding: 12px 16px; border-radius: 12px;
    background: var(--warn-soft); border: 1px solid rgba(217, 119, 6, 0.22);
    color: var(--warn); font-size: 13px; font-weight: 600;
  }
  .callout svg { flex-shrink: 0; }

  .b-side {
    background: linear-gradient(180deg, rgba(15, 28, 60, 0.04), rgba(15, 28, 60, 0));
    border: 1px solid var(--hairline); border-radius: 18px;
    padding: 22px; display: flex; flex-direction: column; gap: 10px;
  }
  .b-tag { font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-quiet); font-weight: 700; }
  .b-status { font-family: var(--font-mono); font-size: 18px; font-weight: 700; color: var(--danger); letter-spacing: -0.01em; }
  .b-side p { font-size: 13px; }

  @media (max-width: 880px) { .billing { grid-template-columns: 1fr; } }
  @media (max-width: 560px) { .billing { padding: 22px 20px; } .b-main h3 { font-size: 19px; } .callout { font-size: 12px; padding: 10px 12px; } }
</style>
