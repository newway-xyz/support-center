---
import Logo from './Logo.astro';
import { useTranslations, type Lang } from '../i18n/utils';
import { DISCORD_INVITE } from '../config';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const colHrefs: string[][] = [
  ['#versions', '#install', '#issues', '#config'],
  ['#account', '#billing', '#', DISCORD_INVITE],
  [DISCORD_INVITE, '#', '#', '#'],
];

const isExternal = (href: string) => href.startsWith('http');
---

<footer class="site-footer">
  <div class="container footer-inner glass">
    <div class="brand-col">
      <Logo lang={lang} />
      <p>{t.footer.tagline}</p>
    </div>

    {t.footer.cols.map((c, ci) => (
      <nav class="col">
        <h4>{c.title}</h4>
        <ul>
          {c.links.map((l, li) => {
            const href = colHrefs[ci]?.[li] ?? '#';
            const ext = isExternal(href);
            return (
              <li>
                <a
                  href={href}
                  target={ext ? '_blank' : undefined}
                  rel={ext ? 'noopener noreferrer' : undefined}
                >
                  {l}
                </a>
              </li>
            );
          })}
        </ul>
      </nav>
    ))}
  </div>

  <div class="container copy">
    <p>{t.footer.copyright}</p>
    <p class="mono">v1.0</p>
  </div>
</footer>

<style>
  .site-footer { padding: 40px 0 28px; margin-top: 24px; }
  .footer-inner { display: grid; grid-template-columns: 1.6fr 1fr 1fr 1fr; gap: 36px; padding: 32px 32px 28px; }
  .brand-col { display: flex; flex-direction: column; gap: 14px; max-width: 320px; }
  .brand-col p { font-size: 13px; }

  .col h4 { font-size: 13px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-quiet); font-weight: 700; margin-bottom: 14px; }
  .col ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 8px; }
  .col a { font-size: 14px; color: var(--text-muted); transition: color 120ms ease; }
  .col a:hover { color: var(--accent-2); }

  .copy { display: flex; justify-content: space-between; align-items: center; padding-top: 24px; margin-top: 8px; color: var(--text-quiet); font-size: 12px; flex-wrap: wrap; gap: 8px; }
  .copy p { font-size: 12px; color: var(--text-quiet); }

  @media (max-width: 880px) { .footer-inner { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) { .footer-inner { grid-template-columns: 1fr; } }
</style>
