---
import Logo from './Logo.astro';

const columns = [
  {
    title: 'Product',
    links: ['Versions', 'Installation', 'Common Issues', 'Game Settings'],
  },
  {
    title: 'Help',
    links: ['Account Help', 'Billing', 'Reset HWID', 'Open a Ticket'],
  },
  {
    title: 'Community',
    links: ['Discord', 'Status', 'Changelog', 'Roadmap'],
  },
];
---

<footer class="site-footer">
  <div class="container footer-inner glass">
    <div class="brand-col">
      <Logo />
      <p>NewWay Support Center — installation guides, troubleshooting and account help.</p>
    </div>

    {columns.map((c) => (
      <nav class="col">
        <h4>{c.title}</h4>
        <ul>
          {c.links.map((l) => <li><a href="#">{l}</a></li>)}
        </ul>
      </nav>
    ))}
  </div>

  <div class="container copy">
    <p>© 2026 NewWay · Support resolves most issues in under 30s</p>
    <p class="mono">v1.0 · build {Math.random().toString(16).slice(2, 8)}</p>
  </div>
</footer>

<style>
  .site-footer { padding: 40px 0 28px; margin-top: 24px; }
  .footer-inner {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: 36px;
    padding: 32px 32px 28px;
  }
  .brand-col { display: flex; flex-direction: column; gap: 14px; max-width: 320px; }
  .brand-col p { font-size: 13px; }

  .col h4 { font-size: 13px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-quiet); font-weight: 700; margin-bottom: 14px; }
  .col ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 8px; }
  .col a { font-size: 14px; color: var(--text-muted); transition: color 120ms ease; }
  .col a:hover { color: var(--accent-2); }

  .copy {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 24px;
    margin-top: 8px;
    color: var(--text-quiet);
    font-size: 12px;
    flex-wrap: wrap;
    gap: 8px;
  }
  .copy p { font-size: 12px; color: var(--text-quiet); }

  @media (max-width: 880px) {
    .footer-inner { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .footer-inner { grid-template-columns: 1fr; }
  }
</style>
