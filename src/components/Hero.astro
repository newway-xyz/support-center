---
const popular = [
  'GTA crashes after injection',
  'Sec_E_invalid_token',
  'HWID is incorrect',
  'RDR2 crashes',
];
---

<section class="hero">
  <div class="container hero-inner">
    <div class="halo" aria-hidden="true"></div>

    <span class="chip accent fade-up">
      <span class="dot"></span>
      Support resolves most issues in under 30 seconds
    </span>

    <h1 class="title fade-up">
      NewWay <span class="grad">Support Center</span>
    </h1>

    <p class="lede fade-up">
      Installation guides, troubleshooting, account help and frequently asked questions —
      solve common issues in under 30 seconds, before opening a ticket.
    </p>

    <form class="search glass-strong fade-up" role="search" onsubmit="event.preventDefault()">
      <svg class="icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7" />
        <path d="m20 20-3.5-3.5" />
      </svg>
      <input
        id="globalSearch"
        type="search"
        placeholder="Search errors, guides, account help…"
        autocomplete="off"
        aria-label="Search the support center"
      />
      <kbd class="hint">/</kbd>
      <button type="submit" class="btn btn-primary submit">
        <span class="submit-label">Search</span>
        <svg class="submit-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
      </button>
    </form>

    <div class="quick fade-up" aria-label="Quick links">
      <a href="#versions" class="quick-link">
        <span>Choose Your Version</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
      </a>
      <a href="#issues" class="quick-link">
        <span>Common Issues</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
      </a>

      <div class="divider"></div>

      <span class="quick-label">Popular</span>
      {popular.map((p) => (
        <a href="#issues" class="popular-link">{p}</a>
      ))}
    </div>
  </div>
</section>

<script>
  const input = document.getElementById('globalSearch') as HTMLInputElement | null;

  document.addEventListener('keydown', (e) => {
    const target = e.target as HTMLElement | null;
    const editing = target && (target.tagName === 'INPUT' || target.tagName === 'TEXTAREA' || target.isContentEditable);
    if (e.key === '/' && !editing) {
      e.preventDefault();
      input?.focus();
    }
  });

  if (input) {
    input.addEventListener('input', () => {
      const q = input.value.trim().toLowerCase();
      const items = document.querySelectorAll<HTMLElement>('[data-search]');
      let visibleCount = 0;
      items.forEach((el) => {
        const haystack = (el.dataset.search || el.textContent || '').toLowerCase();
        const match = q === '' || haystack.includes(q);
        el.style.display = match ? '' : 'none';
        if (match) visibleCount++;
      });
      document.querySelectorAll<HTMLElement>('[data-search-empty]').forEach((el) => {
        el.style.display = q && visibleCount === 0 ? 'block' : 'none';
      });
      document.body.dataset.filtering = q ? 'true' : 'false';
    });
  }
</script>

<style>
  .hero { padding: 56px 0 48px; position: relative; }
  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 22px;
    position: relative;
  }
  .halo {
    position: absolute;
    inset: -40px 0 0 0;
    background: radial-gradient(600px 240px at 50% 30%, rgba(30,156,255,0.18), transparent 65%);
    z-index: -1;
    pointer-events: none;
  }
  .chip .dot {
    width: 6px; height: 6px;
    background: var(--accent);
    border-radius: 50%;
    box-shadow: 0 0 0 4px rgba(30, 156, 255, 0.18);
  }
  .title {
    font-size: clamp(40px, 6vw, 72px);
    line-height: 1.02;
    letter-spacing: -0.035em;
    max-width: 900px;
  }
  .grad {
    background: linear-gradient(180deg, #1ea4ff 0%, #0072d4 70%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .lede {
    font-size: 17px;
    max-width: 640px;
  }
  .search {
    display: flex;
    align-items: center;
    gap: 12px;
    width: min(640px, 100%);
    padding: 10px 10px 10px 18px;
    border-radius: 999px;
    margin-top: 8px;
  }
  .search .icon { color: var(--text-quiet); flex-shrink: 0; }
  .search input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--text);
    font-size: 16px;
    padding: 6px 0;
    min-width: 0;
  }
  .search input::placeholder { color: var(--text-quiet); }
  .search .hint {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-quiet);
    padding: 4px 8px;
    border-radius: 6px;
    background: rgba(15, 28, 60, 0.06);
    border: 1px solid var(--hairline);
  }
  .search .btn { padding: 10px 18px; }
  .search .submit-icon { display: none; }

  .quick {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 8px;
  }
  .quick-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    border-radius: 999px;
    background: var(--surface-strong);
    border: 1px solid var(--border-strong);
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
    transition: transform 120ms ease;
  }
  .quick-link:hover { transform: translateY(-1px); }
  .quick-link svg { color: var(--accent-2); }
  .divider {
    width: 1px;
    height: 22px;
    background: var(--hairline);
    margin: 0 4px;
  }
  .quick-label {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-quiet);
    font-weight: 700;
  }
  .popular-link {
    font-size: 13px;
    color: var(--text-muted);
    padding: 6px 10px;
    border-radius: 999px;
    transition: all 120ms ease;
  }
  .popular-link:hover { color: var(--accent-2); background: var(--accent-soft); }

  @media (max-width: 600px) {
    .hero { padding: 32px 0 28px; }
    .search { padding: 8px 8px 8px 14px; gap: 8px; }
    .search input { font-size: 15px; }
    .search .hint { display: none; }
    .search .submit { padding: 10px 12px; min-width: 40px; justify-content: center; }
    .search .submit-label { display: none; }
    .search .submit-icon { display: block; }
    .quick { gap: 6px; }
    .quick-link { padding: 7px 12px; font-size: 12px; }
    .divider, .quick-label { display: none; }
    .popular-link { font-size: 12px; padding: 5px 8px; }
  }
</style>
