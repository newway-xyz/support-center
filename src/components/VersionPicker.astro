---
const versions = [
  {
    badge: 'GTA V',
    badgeTone: 'neutral',
    code: 'LS',
    title: 'Legacy Solo',
    summary: 'Solo & story sessions, isolated from everyone else.',
    features: [
      { text: 'Play alone', ok: true },
      { text: 'Solo sessions', ok: true },
      { text: 'No public sessions', ok: false },
      { text: 'No sessions with other modders', ok: false },
    ],
    battleye: { label: 'OFF', tone: 'warn' },
    recommended: false,
  },
  {
    badge: 'GTA V Enhanced',
    badgeTone: 'accent',
    code: 'ES',
    title: 'Enhanced Solo',
    summary: 'Private sessions shared with other modders only.',
    features: [
      { text: 'Play with other modders', ok: true },
      { text: 'No public sessions', ok: false },
      { text: 'Battleye must be disabled', ok: true, note: true },
    ],
    battleye: { label: 'MUST BE OFF', tone: 'warn' },
    recommended: false,
  },
  {
    badge: 'GTA V Enhanced',
    badgeTone: 'accent',
    code: 'BE',
    title: 'Enhanced BE Bypass',
    summary: 'The modern way to play — full public lobbies with everyone.',
    features: [
      { text: 'Public sessions', ok: true },
      { text: 'Play with regular players', ok: true },
      { text: 'Play with other modders', ok: true },
    ],
    battleye: { label: 'KEEP ON', tone: 'success' },
    recommended: true,
  },
];
---

<section id="versions" class="section-versions">
  <div class="container">
    <header class="section-head">
      <span class="eyebrow">01 — Get Started</span>
      <h2>Which version should I use?</h2>
      <p class="lede">Pick the build that matches how you want to play. Battleye requirements differ per version.</p>
    </header>

    <div class="grid cols-3 versions">
      {versions.map((v) => (
        <article
          class={`card glass ${v.recommended ? 'is-recommended' : ''}`}
          data-search={`${v.badge} ${v.title} ${v.summary} ${v.features.map(f => f.text).join(' ')}`}
        >
          {v.recommended && <span class="ribbon">★ Recommended</span>}

          <div class="card-top">
            <span class={`badge ${v.badgeTone}`}>{v.badge}</span>
            <span class="code mono">{v.code}</span>
          </div>

          <h3 class="title">{v.title}</h3>
          <p class="summary">{v.summary}</p>

          <ul class="features">
            {v.features.map((f) => (
              <li class={f.ok ? 'ok' : 'no'}>
                {f.ok ? (
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                ) : (
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                )}
                <span>{f.text}</span>
              </li>
            ))}
          </ul>

          <div class="battleye">
            <span class="be-label">Battleye</span>
            <span class={`be-value ${v.battleye.tone}`}>{v.battleye.label}</span>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .section-versions { padding-top: 24px; }

  .versions { align-items: stretch; }

  .card {
    position: relative;
    padding: 26px 24px 22px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: transform 180ms ease, box-shadow 220ms ease;
  }
  .card:hover { transform: translateY(-3px); box-shadow: var(--shadow-lift), var(--shadow-ring); }

  .is-recommended {
    background: linear-gradient(180deg, rgba(255,255,255,0.92), rgba(232,243,255,0.65));
    border-color: rgba(30, 156, 255, 0.4);
    box-shadow: 0 14px 40px rgba(30, 156, 255, 0.18), var(--shadow-ring);
  }

  .ribbon {
    position: absolute;
    top: -10px;
    right: 20px;
    background: linear-gradient(180deg, #1ea4ff, #0e88e6);
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 6px 12px;
    border-radius: 999px;
    box-shadow: 0 6px 14px rgba(14, 136, 230, 0.4);
  }

  .card-top { display: flex; align-items: center; justify-content: space-between; }
  .badge {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 5px 10px;
    border-radius: 6px;
  }
  .badge.neutral { background: rgba(15, 28, 60, 0.06); color: var(--text-muted); }
  .badge.accent { background: var(--accent-soft); color: var(--accent-2); }

  .code {
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    background: var(--surface-strong);
    border: 1px solid var(--border-strong);
    color: var(--accent-2);
    font-size: 12px;
    font-weight: 700;
  }

  .card .title { font-size: 22px; letter-spacing: -0.02em; }
  .summary { font-size: 14px; }

  .features { list-style: none; margin: 4px 0 0; padding: 0; display: flex; flex-direction: column; gap: 8px; flex: 1; }
  .features li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: var(--text);
    line-height: 1.4;
  }
  .features li svg { flex-shrink: 0; padding: 4px; border-radius: 6px; width: 22px; height: 22px; }
  .features li.ok svg { background: var(--success-soft); color: var(--success); }
  .features li.no svg { background: var(--danger-soft); color: var(--danger); }
  .features li.no span { color: var(--text-muted); }

  .battleye {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 12px;
    border-radius: 12px;
    border: 1px dashed var(--border-strong);
    background: rgba(255,255,255,0.5);
    margin-top: 6px;
  }
  .be-label { font-size: 12px; color: var(--text-muted); letter-spacing: 0.06em; text-transform: uppercase; font-weight: 600; }
  .be-value {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 6px;
  }
  .be-value.success { background: var(--success-soft); color: var(--success); }
  .be-value.warn { background: var(--warn-soft); color: var(--warn); }
  .be-value.danger { background: var(--danger-soft); color: var(--danger); }
</style>
