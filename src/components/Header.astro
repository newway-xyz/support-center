---
import Logo from './Logo.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { useTranslations, type Lang } from '../i18n/utils';
import { DISCORD_INVITE } from '../config';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const nav = [
  { label: t.nav.versions, href: '#versions' },
  { label: t.nav.install, href: '#install' },
  { label: t.nav.issues, href: '#issues' },
  { label: t.nav.account, href: '#account' },
  { label: t.nav.support, href: '#support' },
];
---

<header class="site-header">
  <div class="container header-inner glass-strong">
    <Logo lang={lang} />

    <nav class="nav" aria-label="Primary">
      {nav.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>

    <div class="header-cta">
      <LanguageSwitcher current={lang} />
      <a
        href={DISCORD_INVITE}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-primary discord-btn"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.196.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
        </svg>
        <span>{t.nav.openTicket}</span>
      </a>
      <button
        type="button"
        class="menu-toggle"
        aria-label={t.nav.menuOpen}
        aria-expanded="false"
        aria-controls="mobile-nav"
        data-label-open={t.nav.menuOpen}
        data-label-close={t.nav.menuClose}
      >
        <svg class="icon-open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 6h18"/><path d="M3 12h18"/><path d="M3 18h18"/></svg>
        <svg class="icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
    </div>
  </div>

  <nav id="mobile-nav" class="mobile-nav glass-strong" aria-label="Mobile">
    {nav.map((item) => (
      <a href={item.href} class="mobile-link">{item.label}</a>
    ))}
    <div class="mobile-cta">
      <a
        href={DISCORD_INVITE}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-primary"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.196.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
        </svg>
        {t.nav.openTicket}
      </a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.menu-toggle');
  const mobileNav = document.getElementById('mobile-nav');

  const setOpen = (open: boolean) => {
    if (!toggle || !mobileNav) return;
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? (toggle.dataset.labelClose || 'Close') : (toggle.dataset.labelOpen || 'Open'));
    mobileNav.classList.toggle('is-open', open);
    document.body.classList.toggle('menu-open', open);
  };

  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') !== 'true';
    setOpen(open);
  });

  mobileNav?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => setOpen(false));
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setOpen(false);
  });
</script>

<style>
  .site-header { position: sticky; top: 16px; z-index: 50; padding: 0 16px; }
  .header-inner {
    display: flex; align-items: center; justify-content: space-between;
    gap: 24px; padding: 10px 14px 10px 18px; border-radius: 999px; margin-top: 16px;
  }
  .nav { display: flex; gap: 6px; flex: 1; justify-content: center; }
  .nav a {
    padding: 8px 14px; border-radius: 999px; color: var(--text-muted);
    font-size: 14px; font-weight: 500; transition: all 160ms ease;
  }
  .nav a:hover { color: var(--text); background: rgba(255,255,255,0.7); }
  .header-cta { display: flex; gap: 8px; align-items: center; }
  .header-cta .btn { padding: 10px 16px; font-size: 13px; }

  .menu-toggle {
    display: none;
    align-items: center; justify-content: center;
    width: 40px; height: 40px;
    border-radius: 999px;
    background: var(--surface-strong);
    border: 1px solid var(--border-strong);
    color: var(--text);
    box-shadow: var(--shadow-soft);
  }
  .menu-toggle .icon-close { display: none; }
  .menu-toggle[aria-expanded="true"] .icon-open { display: none; }
  .menu-toggle[aria-expanded="true"] .icon-close { display: block; }

  .mobile-nav {
    display: none; flex-direction: column; gap: 4px;
    margin: 12px 16px 0; padding: 14px; border-radius: 20px;
  }
  .mobile-nav.is-open { display: flex; }
  .mobile-link { padding: 12px 14px; border-radius: 12px; color: var(--text); font-weight: 600; font-size: 15px; }
  .mobile-link:hover { background: var(--accent-soft); color: var(--accent-2); }
  .mobile-cta {
    display: grid; grid-template-columns: 1fr; gap: 8px;
    padding-top: 10px; margin-top: 8px; border-top: 1px solid var(--hairline);
  }
  .mobile-cta .btn { justify-content: center; width: 100%; padding: 12px 16px; }

  @media (max-width: 980px) {
    .nav { display: none; }
    .menu-toggle { display: inline-flex; }
  }
  @media (max-width: 520px) {
    .discord-btn span { display: none; }
    .discord-btn { padding: 10px 12px; }
    .header-inner { padding: 8px 10px 8px 14px; gap: 8px; }
  }
</style>
