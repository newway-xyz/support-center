---
import Logo from './Logo.astro';

const nav = [
  { label: 'Versions', href: '#versions' },
  { label: 'Install', href: '#install' },
  { label: 'Issues', href: '#issues' },
  { label: 'Account', href: '#account' },
  { label: 'Support', href: '#support' },
];
---

<header class="site-header">
  <div class="container header-inner glass-strong">
    <Logo />

    <nav class="nav" aria-label="Primary">
      {nav.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>

    <div class="header-cta">
      <a href="#support" class="btn btn-ghost">Open Ticket</a>
      <a href="#" class="btn btn-primary">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
        Join Discord
      </a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 16px;
    z-index: 50;
    padding: 0 16px;
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 10px 14px 10px 18px;
    border-radius: 999px;
    margin-top: 16px;
  }
  .nav {
    display: flex;
    gap: 6px;
    flex: 1;
    justify-content: center;
  }
  .nav a {
    padding: 8px 14px;
    border-radius: 999px;
    color: var(--text-muted);
    font-size: 14px;
    font-weight: 500;
    transition: all 160ms ease;
  }
  .nav a:hover { color: var(--text); background: rgba(255,255,255,0.7); }
  .header-cta { display: flex; gap: 8px; }
  .header-cta .btn { padding: 10px 16px; font-size: 13px; }

  @media (max-width: 880px) {
    .nav { display: none; }
  }
  @media (max-width: 560px) {
    .header-cta .btn-ghost { display: none; }
  }
</style>
