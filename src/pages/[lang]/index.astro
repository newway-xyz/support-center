---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import VersionPicker from '../../components/VersionPicker.astro';
import InstallGuides from '../../components/InstallGuides.astro';
import CommonIssues from '../../components/CommonIssues.astro';
import GameConfig from '../../components/GameConfig.astro';
import AccountHelp from '../../components/AccountHelp.astro';
import Billing from '../../components/Billing.astro';
import SupportCTA from '../../components/SupportCTA.astro';
import Footer from '../../components/Footer.astro';
import { useTranslations, type Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'pt' } },
    { params: { lang: 'zh' } },
    { params: { lang: 'es' } },
    { params: { lang: 'ru' } },
  ];
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
---

<Layout title={t.meta.title} description={t.meta.description} lang={lang}>
  <Header lang={lang} />
  <main>
    <Hero lang={lang} />
    <VersionPicker lang={lang} />
    <InstallGuides lang={lang} />
    <CommonIssues lang={lang} />
    <GameConfig lang={lang} />
    <AccountHelp lang={lang} />
    <Billing lang={lang} />
    <SupportCTA lang={lang} />
  </main>
  <Footer lang={lang} />
</Layout>
